# ============================================================================
# Argus — MedRec Copilot MCP Server
# Copy this file to `.env` and fill in values.
# ============================================================================

# --- Server ---
ARGUS_HOST=0.0.0.0
ARGUS_PORT=8080
ARGUS_LOG_LEVEL=INFO
ARGUS_ENV=dev  # dev | staging | prod

# --- LLM (Gemini via Google AI Studio free tier) ---
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- FHIR server fallback (used only when SHARP context is absent, e.g. local dev) ---
# Example public test servers:
#   https://hapi.fhir.org/baseR4
#   https://server.fire.ly
ARGUS_FALLBACK_FHIR_BASE_URL=https://hapi.fhir.org/baseR4
ARGUS_FALLBACK_FHIR_TOKEN=

# --- Reference KB ---
ARGUS_REFERENCE_KB_PATH=argus/reference/reference.sqlite

# --- ML artifacts ---
ARGUS_MODEL_DIR=argus/ml/artifacts

# --- External APIs ---
RXNAV_BASE_URL=https://rxnav.nlm.nih.gov/REST
RXNAV_CACHE_TTL_DAYS=7

# --- Feature flags ---
ARGUS_ENABLE_LLM_REASONING=true
ARGUS_ENABLE_ML_SEVERITY=true
ARGUS_DEFAULT_SEVERITY_THRESHOLD=moderate  # minor | moderate | major
